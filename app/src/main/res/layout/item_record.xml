<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:padding="16dp">

    <!-- 日期 — 左上角 -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#FF2D2D2D"
        android:textSize="20sp"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvScore"
        android:layout_marginEnd="8dp"
        tools:text="2024-01-15 14:30" />

    <!-- 得分 — 右上角 -->
    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFF9800"
        android:textSize="18sp"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        android:includeFontPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/tvDate"
        tools:text="12345" />

    <!-- 时长 — 左下角 -->
    <TextView
        android:id="@+id/tvDuration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#FF888888"
        android:textSize="18sp"
        android:fontFamily="sans-serif"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDate"
        android:layout_marginTop="6dp"
        app:layout_constraintEnd_toStartOf="@id/tvNote"
        android:layout_marginEnd="8dp"
        tools:text="03:25" />

    <!-- 备注 — 右下角，固定显示“备注”文字，点击弹窗编辑 -->
    <TextView
        android:id="@+id/tvNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFAAAAAA"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:text="备注"
        android:includeFontPadding="false"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="4dp"
        android:paddingVertical="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvScore"
        android:layout_marginTop="6dp"
        android:layout_marginRight="6dp"
        app:layout_constraintStart_toEndOf="@id/tvDate"
        tools:text="备注" />

</androidx.constraintlayout.widget.ConstraintLayout>